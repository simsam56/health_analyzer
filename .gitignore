# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Sport Performance Dashboard
# ─────────────────────────────────────────────────────────────────────────────

# ── Données sensibles & identifiants ─────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Données Apple Health (volumineuses, privées) ──────────────────────────────
export.xml
export_cda.xml
*.xml

# ── Caches & états intermédiaires ─────────────────────────────────────────────
*.pkl
*.cache
.ah_cache.pkl
.health_cache.pkl
.garmin_cache.pkl
.performos_state.json
.garminconnect/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Environnements virtuels Python ────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/
virtualenv/
.virtualenv/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Rapports générés (conservés localement, pas dans Git) ─────────────────────
# Décommentez pour exclure tous les rapports :
# reports/
reports/dashboard_*.html
reports/AUDIT_*.md

# ── Données Strava brutes (privées) ───────────────────────────────────────────
export_strava/
export_strava/activities/
export_strava/*.csv
workout-routes/

# ── Base de données (trop volumineuse pour git, backup local) ─────────────────
*.db
*.db-shm
*.db-wal
*.bak_*.db

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
.fuse_hidden*
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# ── Éditeurs & IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Frontend Next.js ─────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/

# ── Fichiers debug/temp ─────────────────────────────────────────────────────
server_*.txt
sync_run*.txt
db_check.txt
diagnose_output.txt
apple_calendars_debug.txt
server.pid
server_output.log
server_run.log
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Divers ────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.backup
backups/
dist/
build/
*.egg-info/
frontend/tsconfig.tsbuildinfo
