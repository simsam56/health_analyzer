{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Bord Backend (FastAPI)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--port", "8765", "--reload"],
      "port": 8765
    },
    {
      "name": "Bord Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000
    },
    {
      "name": "Garmin Full Sync",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["garmin_sync_full.py", "--from", "2025-01-01"],
      "port": null
    }
  ]
}
