# PerformOS v3 — Configuration
# Copiez ce fichier en .env et remplissez vos credentials

# ── Garmin Connect ────────────────────────────────────────────
# Nécessaire pour synchroniser les activités récentes (dont le 02/03/2026)
# et obtenir HRV, FC repos, sommeil, Body Battery en temps réel
GARMIN_EMAIL=votre@email.com
GARMIN_PASSWORD=votre_mot_de_passe

# ── Ports serveur ────────────────────────────────────────────
# Pour éviter les conflits avec d'autres projets (ex: balise-ia sur port 3000)
BORD_API_PORT=8765
BORD_FRONTEND_PORT=3000

# ── Strava API (optionnel, via MCP) ───────────────────────────
# Pour le serveur MCP Strava (npm install @r-huijts/strava-mcp-server)
# Obtenez vos tokens sur https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
